APP_NAME=Finance Data Processing API
ENVIRONMENT=development
APP_PORT=8001
# Optional override. Leave unset locally to use project-root sqlite file.
# DATABASE_URL=
AUTO_RUN_MIGRATIONS=true
AUTH_RATE_LIMIT_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
ENABLE_EVENT_DRIVEN_PIPELINE=true
# Optional: comma-separated brokers to publish domain events.
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=finance.domain.events
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
